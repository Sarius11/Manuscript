{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.cache/tsbuildinfo/electron.tsbuildinfo",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "types": ["node"],
    "rootDir": ".",
    "outDir": "dist-electron",
    "noEmit": false,
    "declaration": true,
    "sourceMap": true,
    "verbatimModuleSyntax": false
  },
  "include": ["electron/**/*.ts", "core/**/*.ts", "types/**/*.ts"]
}
